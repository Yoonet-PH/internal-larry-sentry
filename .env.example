# Neon connection string (Dashboard → Connect → Connection string)
# Use the pooled connection string for serverless (recommended on Vercel).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Slack Incoming Webhook URL for Larry notifications (optional in local dev)
# Create in Slack → Apps → Incoming Webhooks, then paste the URL here
SLACK_WEBHOOK_URL=

# Secures the Vercel Cron endpoint (required in production for schedule notifications)
CRON_SECRET=your-random-secret-here
