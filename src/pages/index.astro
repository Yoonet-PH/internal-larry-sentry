---

import Layout from '../layouts/Layout.astro';

import { USERS } from '../lib/status';
import { SCHEDULE_USERS } from '../lib/schedule-users';



export const prerender = false;



const users = USERS;
const scheduleUsers = SCHEDULE_USERS;

---



<Layout title="Who is using Larry?">

  <main class="dashboard-main">
    <section class="dashboard-plan panel-card" aria-labelledby="plan-heading">
      <div class="plan-bar">
        <div class="plan-bar-head">
          <h2 id="plan-heading" class="plan-title">Claude plan</h2>
          <p class="plan-subtitle">Select your plan while on Larry.</p>
        </div>

        <div class="plan-actions">
          <button type="button" class="plan-action btn-outline" data-plan="max" aria-disabled="true">
            Max
          </button>
          <button type="button" class="plan-action btn-outline" data-plan="api" aria-disabled="true">
            API
          </button>
        </div>

        <div id="plan-credits" class="plan-credits hidden">
          <div id="plan-credits-view" class="plan-credits-row">
            <span id="plan-credits-label" class="plan-credits-text">Credits: —</span>
            <button type="button" id="plan-credits-edit" class="plan-credits-edit" disabled>Edit</button>
          </div>
          <form id="plan-credits-form" class="plan-credits-form hidden">
            <label class="sr-only" for="plan-credits-input">Remaining credits (%)</label>
            <div class="plan-credits-form-row">
              <input
                id="plan-credits-input"
                class="scheduler-input plan-credits-input"
                type="number"
                min="0"
                max="100"
                step="1"
                placeholder="%"
                required
              />
              <button type="submit" class="btn-primary plan-credits-save">Save</button>
              <button type="button" id="plan-credits-cancel" class="btn-outline plan-credits-cancel">Cancel</button>
            </div>
          </form>
        </div>
      </div>

      <p id="plan-error" class="plan-message hidden" role="alert"></p>
    </section>

    <div class="dashboard-columns">
      <section class="dashboard-panel dashboard-status panel-card">
        <header class="dashboard-header">
          <h1 class="dashboard-title">Who is using Larry right now?</h1>
          <p class="dashboard-subtitle">
            Click on your team name when you open Larry.<br />
            Everyone on this page sees the same status.
          </p>
        </header>



        <div id="status-banner" role="status" aria-live="polite" data-status="free">
          <div id="status-banner-main">Larry is free to use</div>
          <p id="status-banner-credits" class="status-banner-sub hidden"></p>
        </div>



        <div class="user-grid">

          {

            users.map((user) => (

              <article class="user-card" data-user={user}>
                <h2 class="user-card-name">{user}</h2>

                <button

                  type="button"

                  class="user-action btn-primary"

                  data-user={user}

                >

                  I'm on Larry

                </button>

              </article>

            ))

          }

        </div>

      </section>



      <aside class="dashboard-panel dashboard-scheduler panel-card scheduler-panel" aria-labelledby="scheduler-heading">
        <div class="scheduler-layout">
          <div class="scheduler-upcoming">
            <h3 class="scheduler-section-title">Upcoming</h3>
            <p class="scheduler-timezone">Philippines Time (GMT+8)</p>
            <ul id="schedule-list" class="schedule-list" aria-live="polite">
              <li class="scheduler-empty">Loading schedule…</li>
            </ul>
          </div>

          <div class="scheduler-book">
            <header class="scheduler-book-header">
              <h2 id="scheduler-heading" class="scheduler-heading">Schedule Larry</h2>
              <p class="scheduler-book-copy">
                Book a time slot so the team knows when Larry is reserved. All times are Philippines Time (GMT+8).
              </p>
            </header>

            <form id="schedule-form" class="scheduler-form">
              <div class="space-y-2">
                <label class="scheduler-label" for="schedule-person">User</label>
                <select id="schedule-person" class="scheduler-input" required>
                  <option value="" disabled hidden selected>Select your name</option>
                  {
                    scheduleUsers.map((name) => (
                      <option value={name}>{name}</option>
                    ))
                  }
                </select>
              </div>

              <div class="space-y-2">
                <label class="scheduler-label" for="schedule-date">Date</label>
                <input id="schedule-date" class="scheduler-input" type="date" required />
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-2">
                  <label class="scheduler-label" for="schedule-start">Start</label>
                  <input id="schedule-start" class="scheduler-input" type="time" required />
                </div>
                <div class="space-y-2">
                  <label class="scheduler-label" for="schedule-end">End</label>
                  <input id="schedule-end" class="scheduler-input" type="time" required />
                </div>
              </div>

              <p id="schedule-error" class="scheduler-message hidden" role="alert"></p>
              <p id="schedule-success" class="scheduler-message scheduler-message-success hidden" role="status"></p>

              <button type="submit" class="btn-primary" id="schedule-submit">
                Book Larry
              </button>
            </form>
          </div>
        </div>
      </aside>

    </div>

  </main>

  <div id="larry-reminder-modal" class="modal hidden" role="dialog" aria-modal="true" aria-labelledby="larry-reminder-title">
    <div class="modal-backdrop" data-dismiss-modal></div>
    <div class="modal-panel">
      <p id="larry-reminder-title" class="modal-message">
        Please remember to select the plan you are using and update the remaining credits once you are finished.
      </p>
      <button type="button" class="btn-primary modal-dismiss" id="larry-reminder-dismiss">OK</button>
    </div>
  </div>

</Layout>



<script>

  import { USERS, CLAUDE_PLAN_LABELS } from '../lib/status';
  import { SCHEDULE_USERS } from '../lib/schedule-users';
  import {
    APP_TIMEZONE_LABEL,
    formatManilaDateInput,
    formatManilaTimeInput,
    formatScheduleRange,
    parseManilaDateTime,
    roundUpToNextHalfHourManila,
  } from '../lib/timezone';



  type User = (typeof USERS)[number];
  type ScheduleUser = (typeof SCHEDULE_USERS)[number];
  type ClaudePlan = keyof typeof CLAUDE_PLAN_LABELS;

  type StatusPayload = {
    activeUser: User | null;
    claudePlan: ClaudePlan | null;
    remainingCredits: number | null;
  };



  type ScheduleEntry = {

    id: string;

    user: ScheduleUser;

    startsAt: string;

    endsAt: string;

  };



  const banner = document.getElementById('status-banner')!;
  const bannerMain = document.getElementById('status-banner-main')!;
  const bannerCredits = document.getElementById('status-banner-credits')!;

  const buttons = document.querySelectorAll<HTMLButtonElement>('.user-action');
  const cards = document.querySelectorAll<HTMLElement>('.user-card');

  const planButtons = document.querySelectorAll<HTMLButtonElement>('.plan-action');
  const planError = document.getElementById('plan-error')!;
  const planCredits = document.getElementById('plan-credits')!;
  const planCreditsView = document.getElementById('plan-credits-view')!;
  const planCreditsLabel = document.getElementById('plan-credits-label')!;
  const planCreditsEdit = document.getElementById('plan-credits-edit') as HTMLButtonElement;
  const planCreditsForm = document.getElementById('plan-credits-form') as HTMLFormElement;
  const planCreditsInput = document.getElementById('plan-credits-input') as HTMLInputElement;
  const planCreditsCancel = document.getElementById('plan-credits-cancel') as HTMLButtonElement;

  const reminderModal = document.getElementById('larry-reminder-modal')!;
  const reminderDismiss = document.getElementById('larry-reminder-dismiss') as HTMLButtonElement;

  let activeUser: User | null = null;
  let localUser: User | null = null;
  let claudePlan: ClaudePlan | null = null;
  let remainingCredits: number | null = null;
  let pollTimer: ReturnType<typeof setInterval> | null = null;

  const SESSION_USER_KEY = 'larry-session-user';

  function isSessionUser(value: string | null): value is User {
    return value !== null && (USERS as readonly string[]).includes(value);
  }

  function persistSessionUser(user: User | null) {
    if (user) {
      sessionStorage.setItem(SESSION_USER_KEY, user);
    } else {
      sessionStorage.removeItem(SESSION_USER_KEY);
    }
  }

  function syncSessionUser() {
    const stored = sessionStorage.getItem(SESSION_USER_KEY);

    if (activeUser === null) {
      localUser = null;
      sessionStorage.removeItem(SESSION_USER_KEY);
      return;
    }

    if (isSessionUser(stored) && stored === activeUser) {
      localUser = stored;
      return;
    }

    if (localUser !== null && localUser !== activeUser) {
      localUser = null;
    }
  }

  function clearPlanError() {
    planError.textContent = '';
    planError.classList.add('hidden');
  }

  function showPlanError(message: string) {
    planError.textContent = message;
    planError.classList.remove('hidden');
  }



  function renderBanner(user: User | null, scheduledUser: ScheduleUser | null) {
    if (user) {
      banner.dataset.status = 'busy';
      const planSuffix = claudePlan ? ` (${CLAUDE_PLAN_LABELS[claudePlan]})` : '';

      if (scheduledUser) {
        banner.dataset.combined = 'true';
        bannerMain.textContent = `${scheduledUser} (${user}) is currently using Larry${planSuffix}`;
      } else {
        delete banner.dataset.combined;
        bannerMain.textContent = `${user} is currently using Larry${planSuffix}`;
      }

      if (claudePlan === 'api' && remainingCredits !== null) {
        bannerCredits.textContent = `Remaining credits: ${remainingCredits}%`;
        bannerCredits.classList.remove('hidden');
      } else {
        bannerCredits.textContent = '';
        bannerCredits.classList.add('hidden');
      }

      return;
    }

    delete banner.dataset.combined;
    banner.dataset.status = 'free';
    bannerMain.textContent = 'Larry is free to use';
    bannerCredits.textContent = '';
    bannerCredits.classList.add('hidden');
  }

  function canEditPlan(): boolean {
    return activeUser !== null && localUser === activeUser;
  }

  function renderPlanSection() {
    const editable = canEditPlan();

    planButtons.forEach((button) => {
      const plan = button.dataset.plan as ClaudePlan;
      const isSelected = claudePlan === plan;

      button.setAttribute('aria-disabled', String(!editable));
      button.classList.toggle('plan-action-locked', !editable);
      button.classList.toggle('btn-primary', isSelected);
      button.classList.toggle('btn-outline', !isSelected);
    });

    if (claudePlan === 'api') {
      planCredits.classList.remove('hidden');
      planCreditsLabel.textContent =
        remainingCredits !== null
          ? `Credits: ${remainingCredits}%`
          : 'Credits: —';
      planCreditsEdit.disabled = !editable;

      if (!editable) {
        hideCreditsEditor();
      }
    } else {
      planCredits.classList.add('hidden');
      hideCreditsEditor();
    }
  }

  function showCreditsEditor() {
    planCreditsView.classList.add('hidden');
    planCreditsForm.classList.remove('hidden');
    planCreditsInput.value =
      remainingCredits !== null ? String(remainingCredits) : '';
    planCreditsInput.focus();
  }

  function hideCreditsEditor() {
    planCreditsView.classList.remove('hidden');
    planCreditsForm.classList.add('hidden');
  }

  function showReminderModal() {
    reminderModal.classList.remove('hidden');
    reminderDismiss.focus();
  }

  function hideReminderModal() {
    reminderModal.classList.add('hidden');
  }



  function renderButtons(user: User | null) {

    buttons.forEach((button) => {

      const name = button.dataset.user as User;

      const isActive = user === name;

      const isBlocked = user !== null && user !== name;



      button.disabled = isBlocked;

      button.textContent = isActive ? 'Leave Larry' : "I'm on Larry";

      button.classList.toggle('btn-primary', !isActive);

      button.classList.toggle('btn-outline', isActive);

    });



    cards.forEach((card) => {

      const name = card.dataset.user as User;

      if (user === name) {

        card.dataset.active = 'true';

      } else {

        delete card.dataset.active;

      }

    });

  }



  function getActiveScheduleUser(): ScheduleUser | null {
    const active = schedule.find(isScheduleActive);
    return active?.user ?? null;
  }

  function applyStatus(status: StatusPayload) {
    activeUser = status.activeUser;
    claudePlan = status.claudePlan;
    remainingCredits = status.remainingCredits;

    syncSessionUser();

    renderBanner(activeUser, getActiveScheduleUser());
    renderButtons(activeUser);
    renderPlanSection();
  }



  async function fetchStatus(): Promise<StatusPayload> {
    const response = await fetch('/api/status');
    if (!response.ok) throw new Error('Failed to fetch status');
    const data = await response.json();
    return {
      activeUser: data.activeUser ?? null,
      claudePlan: data.claudePlan ?? null,
      remainingCredits:
        typeof data.remainingCredits === 'number' ? data.remainingCredits : null,
    };
  }

  async function refreshStatus() {
    try {
      const status = await fetchStatus();
      applyStatus(status);
    } catch {
      banner.dataset.status = 'error';
      bannerMain.textContent = 'Could not load status. Retrying…';
      bannerCredits.classList.add('hidden');
    }
  }

  async function updateStatus(user: User): Promise<'enter' | 'leave' | 'conflict'> {
    const action = activeUser === user ? 'leave' : 'enter';

    const response = await fetch('/api/status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user, action }),
    });

    const data = await response.json();

    if (response.status === 409) {
      applyStatus({
        activeUser: data.activeUser ?? null,
        claudePlan: data.claudePlan ?? null,
        remainingCredits:
          typeof data.remainingCredits === 'number' ? data.remainingCredits : null,
      });
      return 'conflict';
    }

    if (!response.ok) {
      throw new Error(data.error ?? 'Failed to update status');
    }

    if (action === 'enter') {
      localUser = user;
      persistSessionUser(user);
    } else {
      localUser = null;
      persistSessionUser(null);
    }

    applyStatus({
      activeUser: data.activeUser ?? null,
      claudePlan: data.claudePlan ?? null,
      remainingCredits:
        typeof data.remainingCredits === 'number' ? data.remainingCredits : null,
    });

    return action;
  }

  async function setPlan(user: User, plan: ClaudePlan) {
    const response = await fetch('/api/status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user, action: 'setPlan', plan }),
    });

    const data = await response.json();
    if (!response.ok) {
      throw new Error(data.error ?? 'Failed to set plan');
    }

    applyStatus({
      activeUser: data.activeUser ?? null,
      claudePlan: data.claudePlan ?? null,
      remainingCredits:
        typeof data.remainingCredits === 'number' ? data.remainingCredits : null,
    });
  }

  async function updateCredits(user: User, credits: number) {
    const response = await fetch('/api/status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user, action: 'updateCredits', remainingCredits: credits }),
    });

    const data = await response.json();
    if (!response.ok) {
      throw new Error(data.error ?? 'Failed to update credits');
    }

    applyStatus({
      activeUser: data.activeUser ?? null,
      claudePlan: data.claudePlan ?? null,
      remainingCredits:
        typeof data.remainingCredits === 'number' ? data.remainingCredits : null,
    });
  }



  buttons.forEach((button) => {
    button.addEventListener('click', async () => {
      const user = button.dataset.user as User;
      button.disabled = true;

      try {
        const result = await updateStatus(user);
        if (result === 'enter') {
          showReminderModal();
        }
      } catch {
        await refreshStatus();
      } finally {
        renderButtons(activeUser);
      }
    });
  });

  planButtons.forEach((button) => {
    button.addEventListener('click', async () => {
      clearPlanError();

      if (!canEditPlan()) {
        if (!activeUser) {
          showPlanError('Click "I\'m on Larry" above before selecting a plan.');
        } else {
          showPlanError(
            `Click "I'm on Larry" as ${activeUser} in this browser to select a plan.`,
          );
        }
        return;
      }

      const plan = button.dataset.plan as ClaudePlan;
      button.setAttribute('aria-disabled', 'true');
      button.classList.add('plan-action-locked');

      try {
        await setPlan(localUser!, plan);
        clearPlanError();
      } catch (error) {
        showPlanError(error instanceof Error ? error.message : 'Failed to set plan.');
        await refreshStatus();
      } finally {
        renderPlanSection();
      }
    });
  });

  planCreditsEdit.addEventListener('click', () => {
    if (!canEditPlan()) return;
    showCreditsEditor();
  });

  planCreditsCancel.addEventListener('click', () => {
    hideCreditsEditor();
  });

  planCreditsForm.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!localUser || !canEditPlan()) return;

    const value = Number(planCreditsInput.value);
    if (!Number.isInteger(value) || value < 0 || value > 100) return;

    planCreditsForm.querySelector<HTMLButtonElement>('.plan-credits-save')!.disabled = true;

    try {
      await updateCredits(localUser, value);
      hideCreditsEditor();
    } catch {
      await refreshStatus();
    } finally {
      planCreditsForm.querySelector<HTMLButtonElement>('.plan-credits-save')!.disabled = false;
    }
  });

  reminderDismiss.addEventListener('click', hideReminderModal);
  reminderModal.querySelectorAll('[data-dismiss-modal]').forEach((el) => {
    el.addEventListener('click', hideReminderModal);
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !reminderModal.classList.contains('hidden')) {
      hideReminderModal();
    }
  });



  refreshStatus();

  pollTimer = setInterval(refreshStatus, 2000);



  const scheduleForm = document.getElementById('schedule-form') as HTMLFormElement;

  const schedulePerson = document.getElementById('schedule-person') as HTMLSelectElement;

  const scheduleDate = document.getElementById('schedule-date') as HTMLInputElement;

  const scheduleStart = document.getElementById('schedule-start') as HTMLInputElement;

  const scheduleEnd = document.getElementById('schedule-end') as HTMLInputElement;

  const scheduleError = document.getElementById('schedule-error')!;

  const scheduleSuccess = document.getElementById('schedule-success')!;

  const scheduleSubmit = document.getElementById('schedule-submit') as HTMLButtonElement;

  const scheduleList = document.getElementById('schedule-list')!;



  let schedule: ScheduleEntry[] = [];

  let schedulePollTimer: ReturnType<typeof setInterval> | null = null;



  function setDefaultScheduleTimes() {
    const now = new Date();
    const start = roundUpToNextHalfHourManila(now);
    const end = new Date(start.getTime() + 60 * 60 * 1000);

    scheduleDate.min = formatManilaDateInput(now);
    scheduleDate.value = formatManilaDateInput(start);
    scheduleStart.value = formatManilaTimeInput(start);
    scheduleEnd.value = formatManilaTimeInput(end);
    schedulePerson.selectedIndex = 0;
  }



  function clearScheduleMessages() {

    scheduleError.classList.add('hidden');

    scheduleSuccess.classList.add('hidden');

    scheduleError.textContent = '';

    scheduleSuccess.textContent = '';

  }



  function showScheduleError(message: string) {

    scheduleSuccess.classList.add('hidden');

    scheduleError.textContent = message;

    scheduleError.classList.remove('hidden');

  }



  function showScheduleSuccess(message: string) {

    scheduleError.classList.add('hidden');

    scheduleSuccess.textContent = message;

    scheduleSuccess.classList.remove('hidden');

  }



  function combineDateAndTime(dateValue: string, timeValue: string): Date | null {
    return parseManilaDateTime(dateValue, timeValue);
  }



  function isScheduleActive(entry: ScheduleEntry): boolean {
    const now = Date.now();
    return new Date(entry.startsAt).getTime() <= now && new Date(entry.endsAt).getTime() > now;
  }

  function isScheduleNext(entry: ScheduleEntry, all: ScheduleEntry[]): boolean {
    const now = Date.now();
    const future = all.filter((item) => new Date(item.startsAt).getTime() > now);
    return future[0]?.id === entry.id;
  }



  function renderSchedule() {
    if (schedule.length === 0) {
      scheduleList.innerHTML = '<li class="scheduler-empty">Nothing scheduled.</li>';
    } else {
      scheduleList.innerHTML = schedule
        .map((entry) => {
          const active = isScheduleActive(entry);
          const next = isScheduleNext(entry, schedule);
          const statusClass = active ? 'schedule-item-active' : next ? 'schedule-item-next' : '';
          const statusLabel = active ? 'Now' : next ? 'Next' : '';

          return `
          <li class="schedule-item ${statusClass}" data-schedule-id="${entry.id}">
            <div class="schedule-item-body">
              <p class="schedule-item-user">${entry.user}</p>
              <p class="schedule-item-time">${formatScheduleRange(entry.startsAt, entry.endsAt)}</p>
              ${statusLabel ? `<span class="schedule-item-badge">${statusLabel}</span>` : ''}
            </div>
            <button type="button" class="schedule-cancel" data-schedule-id="${entry.id}" aria-label="Remove ${entry.user} from schedule">
              Remove
            </button>
          </li>
        `;
        })
        .join('');

      scheduleList.querySelectorAll<HTMLButtonElement>('.schedule-cancel').forEach((button) => {
        button.addEventListener('click', async () => {
          const id = button.dataset.scheduleId;
          if (!id) return;

          button.disabled = true;

          try {
            const response = await fetch('/api/schedule', {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id }),
            });

            if (!response.ok) {
              const data = await response.json();
              throw new Error(data.error ?? 'Failed to remove from schedule');
            }

            await refreshSchedule();
          } catch (error) {
            showScheduleError(error instanceof Error ? error.message : 'Failed to remove from schedule');
          } finally {
            button.disabled = false;
          }
        });
      });
    }

    renderBanner(activeUser, getActiveScheduleUser());
  }



  async function refreshSchedule() {
    try {
      const response = await fetch('/api/schedule');
      if (!response.ok) throw new Error('Failed to load schedule');
      const data = await response.json();
      schedule = data.schedule ?? [];
      renderSchedule();
    } catch {
      scheduleList.innerHTML = '<li class="scheduler-empty">Could not load schedule.</li>';
    }
  }



  scheduleForm.addEventListener('submit', async (event) => {

    event.preventDefault();

    clearScheduleMessages();



    const startsAt = combineDateAndTime(scheduleDate.value, scheduleStart.value);

    const endsAt = combineDateAndTime(scheduleDate.value, scheduleEnd.value);



    if (!startsAt || !endsAt) {

      showScheduleError(`Enter a valid date and time in ${APP_TIMEZONE_LABEL}.`);

      return;

    }



    if (endsAt <= startsAt) {

      showScheduleError('End time must be after start time.');

      return;

    }



    scheduleSubmit.disabled = true;



    try {

      const response = await fetch('/api/schedule', {

        method: 'POST',

        headers: { 'Content-Type': 'application/json' },

        body: JSON.stringify({

          user: schedulePerson.value,

          startsAt: startsAt.toISOString(),

          endsAt: endsAt.toISOString(),

        }),

      });



      const data = await response.json();



      if (!response.ok) {

        showScheduleError(data.error ?? 'Failed to book Larry');

        return;

      }



      showScheduleSuccess('Added to schedule.');

      setDefaultScheduleTimes();

      await refreshSchedule();

    } catch {

      showScheduleError('Failed to book Larry. Try again.');

    } finally {

      scheduleSubmit.disabled = false;

    }

  });



  setDefaultScheduleTimes();

  refreshSchedule();

  schedulePollTimer = setInterval(refreshSchedule, 30000);



  window.addEventListener('beforeunload', () => {

    if (pollTimer) clearInterval(pollTimer);

    if (schedulePollTimer) clearInterval(schedulePollTimer);

  });

</script>


