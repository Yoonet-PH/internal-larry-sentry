---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Larry Status' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Manrope:wght@700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="relative flex min-h-screen flex-col bg-background text-foreground font-sans antialiased">
    <div aria-hidden="true" class="dot-pattern dot-grid-overlay fixed inset-0"></div>
    <div class="relative z-10 flex w-full flex-1 flex-col items-center justify-center">
      <slot />
    </div>
  </body>
</html>
