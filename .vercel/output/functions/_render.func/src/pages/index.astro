---
import Layout from '../layouts/Layout.astro';

const users = ['George', 'Arianne', 'Jep'] as const;
---

<Layout title="Who is using Webflow?">
  <main class="flex min-h-screen flex-col items-center justify-center gap-10 px-6 py-12">
    <div class="w-full max-w-2xl space-y-8 text-center">
      <header class="space-y-2">
        <h1 class="text-3xl font-semibold tracking-tight text-zinc-900 sm:text-4xl">
          Who is using Webflow right now?
        </h1>
        <p class="text-sm text-zinc-500">Tap your name when you open Webflow. Everyone on this page sees the same status.</p>
      </header>

      <div
        id="status-banner"
        role="status"
        aria-live="polite"
        class="rounded-xl border px-6 py-4 text-base font-medium transition-colors duration-200"
      >
        🟢 Webflow is currently free to use.
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        {
          users.map((user) => (
            <article
              class="user-card flex flex-col items-center gap-4 rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm"
              data-user={user}
            >
              <h2 class="text-xl font-semibold text-zinc-900">{user}</h2>
              <button
                type="button"
                class="user-action w-full rounded-lg bg-zinc-900 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-zinc-800 disabled:cursor-not-allowed disabled:bg-zinc-300 disabled:text-zinc-500"
                data-user={user}
              >
                I'm in Webflow
              </button>
            </article>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<script>
  const USERS = ['George', 'Arianne', 'Jep'] as const;
  type User = (typeof USERS)[number];

  const banner = document.getElementById('status-banner')!;
  const buttons = document.querySelectorAll<HTMLButtonElement>('.user-action');

  let activeUser: User | null = null;
  let pollTimer: ReturnType<typeof setInterval> | null = null;

  function renderBanner(user: User | null) {
    if (user) {
      banner.className =
        'rounded-xl border border-amber-300 bg-amber-50 px-6 py-4 text-base font-medium text-amber-900 transition-colors duration-200';
      banner.textContent = `⚠️ ${user} is currently using Webflow!`;
      return;
    }

    banner.className =
      'rounded-xl border border-emerald-200 bg-emerald-50 px-6 py-4 text-base font-medium text-emerald-900 transition-colors duration-200';
    banner.textContent = '🟢 Webflow is currently free to use.';
  }

  function renderButtons(user: User | null) {
    buttons.forEach((button) => {
      const name = button.dataset.user as User;
      const isActive = user === name;
      const isBlocked = user !== null && user !== name;

      button.disabled = isBlocked;
      button.textContent = isActive ? 'Leave Webflow' : "I'm in Webflow";
    });
  }

  function applyStatus(user: User | null) {
    activeUser = user;
    renderBanner(user);
    renderButtons(user);
  }

  async function fetchStatus(): Promise<User | null> {
    const response = await fetch('/api/status');
    if (!response.ok) throw new Error('Failed to fetch status');
    const data = await response.json();
    return data.activeUser ?? null;
  }

  async function refreshStatus() {
    try {
      const user = await fetchStatus();
      applyStatus(user);
    } catch {
      banner.className =
        'rounded-xl border border-red-200 bg-red-50 px-6 py-4 text-base font-medium text-red-900 transition-colors duration-200';
      banner.textContent = 'Could not load status. Retrying…';
    }
  }

  async function updateStatus(user: User) {
    const action = activeUser === user ? 'leave' : 'enter';

    const response = await fetch('/api/status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user, action }),
    });

    const data = await response.json();

    if (response.status === 409) {
      applyStatus(data.activeUser ?? null);
      return;
    }

    if (!response.ok) {
      throw new Error(data.error ?? 'Failed to update status');
    }

    applyStatus(data.activeUser ?? null);
  }

  buttons.forEach((button) => {
    button.addEventListener('click', async () => {
      const user = button.dataset.user as User;
      button.disabled = true;

      try {
        await updateStatus(user);
      } catch {
        await refreshStatus();
      } finally {
        renderButtons(activeUser);
      }
    });
  });

  refreshStatus();
  pollTimer = setInterval(refreshStatus, 2000);

  window.addEventListener('beforeunload', () => {
    if (pollTimer) clearInterval(pollTimer);
  });
</script>
